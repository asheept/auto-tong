{
  "$schema": "https://raw.githubusercontent.com/nicklasmoeller/tauri-v2-schema/main/schema.json",
  "productName": "Auto-Tong",
  "version": "0.1.0",
  "identifier": "com.auto-tong.client",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
